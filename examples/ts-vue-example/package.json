{
	"name": "electron-app",
	"version": "1.0.0",
	"description": "An Electron application with Vue and TypeScript",
	"main": "./out/main/index.mjs",
	"author": "example.com",
	"homepage": "https://electron-vite.org",
	"type": "module",
	"scripts": {
		"dev": "electron-vite dev --watch",
		"build": "pnpm run typecheck && electron-vite build",
		"preview": "electron-vite preview",
		"format": "prettier --write .",
		"typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
		"typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
		"typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
		"bundle:app": "pnpm run build && overlayed bundle --app --no-wait",
		"bundle:site": "pnpm run build && overlayed bundle --site --no-wait",
		"bundle:all": "pnpm run build && overlayed bundle --app --site --no-wait"
	},
	"dependencies": {
		"@overlayed/app": "1.3.13"
	},
	"devDependencies": {
		"@electron-toolkit/tsconfig": "^2.0.0",
		"@electron-toolkit/utils": "^4.0.0",
		"@overlayed/cli": "^1.1.4",
		"@overlayed/electron": "33.3.0-7",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vueuse/core": "^14.3.0",
		"electron": "33.3.0",
		"electron-builder": "^26.15.3",
		"electron-updater": "^6.8.9",
		"electron-vite": "^5.0.0",
		"prettier": "^3.9.5",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.4",
		"vue": "^3.5.39",
		"vue-tsc": "^3.3.7"
	}
}
